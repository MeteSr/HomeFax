{
  "name": "@homegentic/voice-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd ../.. && ts-node agents/voice/server.ts",
    "build": "tsc",
    "start": "node dist/voice/server.js",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^\\./bidtolistRouter$": "<rootDir>/__mocks__/bidtolistRouter.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.95.2",
    "@icp-sdk/core": "^5.4.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "resend": "^6.10.0",
    "stripe": "^22.1.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "babel-jest": "^30.4.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
